{
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "trailingSlash": false,
    "redirects": [
      {
        "source": "/",
        "destination": "/docs",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/docs",
        "destination": "/docs/index.html"
      },
      {
        "source": "/docs/",
        "destination": "/docs/index.html"
      },
      {
        "source": "/docs/**",
        "destination": "/docs/index.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}